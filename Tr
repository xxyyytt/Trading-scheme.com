<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TipTraders</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0a0f1c;
      color: #fff;
      overflow-x: hidden;
    }/* TOP BAR */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 15px;
  background: #111827;
  border-bottom: 1px solid #1f2937;
}

.logo {
  font-weight: bold;
  font-size: 18px;
  letter-spacing: 1px;
}

.status {
  font-size: 12px;
  opacity: 0.8;
}

/* LAYOUT */
.layout {
  display: grid;
  grid-template-columns: 220px 1fr 300px;
  height: calc(100vh - 50px);
}

/* SIDEBAR */
.sidebar {
  background: #0f172a;
  border-right: 1px solid #1f2937;
  padding: 10px;
}

.menu-item {
  padding: 10px;
  margin-bottom: 6px;
  background: #111827;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
}

/* MAIN AREA */
.main {
  padding: 10px;
}

.chart {
  height: 300px;
  background: #111827;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #9ca3af;
  margin-bottom: 10px;
}

.price {
  font-size: 32px;
  font-weight: bold;
  margin-bottom: 10px;
}

.panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.box {
  background: #111827;
  padding: 10px;
  border-radius: 12px;
}

button {
  padding: 10px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 6px;
  width: 100%;
}

.buy { background: #16a34a; color: white; }
.sell { background: #dc2626; color: white; }
.connect { background: #2563eb; color: white; }

input {
  width: 100%;
  padding: 8px;
  margin: 5px 0;
  border-radius: 6px;
  border: none;
  background: #0b1220;
  color: white;
}

/* RIGHT PANEL */
.right {
  background: #0f172a;
  border-left: 1px solid #1f2937;
  padding: 10px;
  overflow-y: auto;
}

.trade {
  background: #111827;
  padding: 10px;
  border-radius: 10px;
  margin-bottom: 10px;
}

.small {
  font-size: 12px;
  opacity: 0.7;
}

.signal {
  font-size: 12px;
  padding: 6px;
  margin: 5px 0;
  background: #0b1220;
  border-left: 3px solid #2563eb;
  border-radius: 6px;
}

  </style>
</head>
<body><div class="topbar">
  <div class="logo">TipTraders</div>
  <div class="status" id="status">Disconnected</div>
</div><div class="layout">  <!-- SIDEBAR -->  <div class="sidebar">
    <div class="menu-item">📊 Dashboard</div>
    <div class="menu-item">📈 Markets</div>
    <div class="menu-item">💼 Portfolio</div>
    <div class="menu-item">⚡ Signals</div>
    <div class="menu-item">⚙ Settings</div>
  </div>  <!-- MAIN -->  <div class="main"><div class="price" id="price">--</div>

<div class="chart">
  Live Chart Area (connect trading chart later)
</div>

<div class="panel">

  <div class="box">
    <h4>Connect</h4>
    <input id="appId" placeholder="App ID" />
    <input id="token" placeholder="API Token (optional)" />
    <button class="connect" onclick="connect()">Connect</button>
  </div>

  <div class="box">
    <h4>Quick Trade</h4>
    <button class="buy" onclick="trade('RISE')">Rise</button>
    <button class="sell" onclick="trade('FALL')">Fall</button>
    <p class="small">Demo trading only</p>
  </div>

</div>

  </div>  <!-- RIGHT PANEL -->  <div class="right"><div class="trade">
  <h4>Market Info</h4>
  <p class="small">Volatility 75 Index</p>
  <p class="small">High volatility synthetic market</p>
</div>

<div class="trade">
  <h4>Signals</h4>
  <div class="signal">BUY momentum detected</div>
  <div class="signal">WAIT consolidation zone</div>
  <div class="signal">SELL resistance level</div>
</div>

<div class="trade">
  <h4>Account</h4>
  <p class="small">Balance: $10,000 (demo)</p>
  <p class="small">Profit: $0</p>
  <p class="small">Loss: $0</p>
</div>

  </div></div><script>
let ws;
let isAuth = false;

function connect() {
  const appId = document.getElementById("appId").value || "1089";
  const token = document.getElementById("token").value;

  ws = new WebSocket(`wss://ws.derivws.com/websockets/v3?app_id=${appId}`);

  ws.onopen = function () {
    document.getElementById("status").innerText = "Connected";

    ws.send(JSON.stringify({ ticks: "R_75" }));

    if (token) {
      ws.send(JSON.stringify({ authorize: token }));
      isAuth = true;
    }
  };

  ws.onmessage = function (msg) {
    const data = JSON.parse(msg.data);

    if (data.tick) {
      document.getElementById("price").innerText = data.tick.quote;
    }

    if (data.authorize) {
      document.getElementById("status").innerText = "Logged in: " + data.authorize.loginid;
    }
  };

  ws.onclose = function () {
    document.getElementById("status").innerText = "Disconnected";
  };
}

function trade(type) {
  if (!ws) return alert("Connect first");
  if (!isAuth) return alert("Demo mode only");

  alert("Order sent: " + type + " (execution layer not added)");
}
</script></body>
</html>
